{
  "name": "cbor-devtools-extension",
  "version": "1.0.0",
  "description": "DevTools extension that auto-decodes Smithy RPC v2 CBOR (`application/cbor`) responses. Works in both Firefox and Chrome.",
  "main": "src/cbor.js",
  "scripts": {
    "test": "vitest run",
    "test:e2e": "npx playwright test --project=panel",
    "test:e2e:smoke": "npx playwright test --project=smoke",
    "test:e2e:all": "npx playwright test",
    "prepare": "git config core.hooksPath .githooks",
    "build:firefox": "web-ext build --source-dir src --artifacts-dir dist",
    "publish:firefox": "node scripts/publish.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "express": "^5.2.1",
    "vitest": "^4.1.9",
    "web-ext": "^10.4.0"
  }
}
