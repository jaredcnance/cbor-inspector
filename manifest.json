{
  "manifest_version": 3,
  "name": "CBOR Decoder",
  "version": "1.0.0",
  "description": "DevTools panel that auto-decodes Smithy RPC v2 CBOR responses with syntax-highlighted JSON output",
  "devtools_page": "devtools.html",
  "permissions": [],
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cbor-decoder@noreply",
      "strict_min_version": "109.0",
      "update_url": "https://code.amazon.com/packages/CBorDebugger/blobs/main/--/updates.json?raw=1"
    }
  }
}
